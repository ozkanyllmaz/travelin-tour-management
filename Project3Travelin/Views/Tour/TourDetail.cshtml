@model Project3Travelin.Dtos.TourDtos.GetTourByIdDto

@{
    ViewData["Title"] = "TourDetail";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

<style>
    /* Star Rating Styles */
    .rating-group {
        margin-bottom: 20px;
    }

    .rating-label {
        display: block;
        font-weight: 600;
        margin-bottom: 8px;
        font-size: 14px;
        color: #333;
    }

    .star-rating {
        display: flex;
        flex-direction: row-reverse;
        gap: 8px;
        align-items: center;
        justify-content: flex-end;
        cursor: pointer;
    }

        .star-rating input {
            display: none;
        }

        .star-rating label {
            font-size: 28px;
            color: #ddd;
            cursor: pointer;
            transition: all 0.2s ease;
            margin: 0;
            padding: 0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 35px;
            height: 35px;
        }

            .star-rating label::before {
                content: "★";
            }

            .star-rating input:checked ~ label,
            .star-rating label:hover,
            .star-rating label:hover ~ label {
                color: #ffc107;
                text-shadow: 0 0 5px rgba(255, 193, 7, 0.5);
            }

        .star-rating input:checked ~ label {
            color: #ffc107;
            text-shadow: 0 0 8px rgba(255, 122, 89, 0.6);
        }

        .star-rating label:hover {
            transform: scale(1.2);
        }

        .star-rating input:checked ~ label {
            transform: scale(1.15);
        }

    @@media (max-width: 768px) {
        .star-rating label

    {
        font-size: 24px;
        width: 30px;
        height: 30px;
    }

    }
</style>

<!-- banner starts -->
<div class="banner trending overflow-hidden">
    <div class="section-shape section-shape1 top-inherit bottom-0" style="background-image: url(/travelin/images/shape8.png);  background-repeat: repeat-x; background-position: bottom center; bottom: -5px !important; z-index: 2; clip-path: inset(2px 0 2px 0) !important;"></div>
    <div class="banner-slide">
        <div class="row shop-slider">
            <div class="col-lg-4 p-0">
                <div class="trend-item1 box-shadow bg-white text-center">
                    <div class="trend-image position-relative">
                        <img src="/travelin/images/new-deal/travel1.jpg" alt="image" class="">
                        <div class="overlay"></div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 p-0">
                <div class="trend-item1 box-shadow bg-white text-center">
                    <div class="trend-image position-relative">
                        <img src="/travelin/images/new-deal/travel2.jpg" alt="image" class="">
                        <div class="overlay"></div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 p-0">
                <div class="trend-item1 box-shadow bg-white text-center">
                    <div class="trend-image position-relative">
                        <img src="/travelin/images/new-deal/travel3.jpg" alt="image" class="">
                        <div class="overlay"></div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 p-0">
                <div class="trend-item1 box-shadow bg-white text-center">
                    <div class="trend-image position-relative">
                        <img src="/travelin/images/new-deal/travel4.jpeg" alt="image" class="">
                        <div class="overlay"></div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 p-0">
                <div class="trend-item1 box-shadow bg-white text-center">
                    <div class="trend-image position-relative">
                        <img src="/travelin/images/new-deal/travel5.jpg" alt="image" class="">
                        <div class="overlay"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="banner-breadcrum position-absolute top-50 mx-auto w-50 start-50 text-center translate-middle">
        <div class="breadcrumb-content text-center">
            <h1 class="mb-0 white">Tur Detayı</h1>
            <nav aria-label="breadcrumb" class="d-block">
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a href="#">Anasayfa</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Tur Detay Sayfası</li>
                </ul>
            </nav>
        </div>
    </div>
</div>
<!-- banner ends -->

<!-- top Destination starts -->
<section class="trending pt-6 pb-0 bg-lgrey">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <div class="single-content">
                    <div id="highlight">
                        <div class="single-full-title border-b mb-2 pb-2">
                            <div class="single-title">
                                <h2 class="mb-1">@Model.Title</h2>
                                <div class="rating-main d-md-flex align-items-center">
                                    <p class="mb-0 me-2"><i class="icon-location-pin"></i> @Model.Country @Model.City</p>
                                    <div class="rating me-2">
                                    </div>
                                    <span>(1,186 Reviews)</span>
                                </div>
                            </div>
                        </div>

                        <div class="description-images mb-4">
                            <img src="@Model.ImageUrl" alt="" class="w-100 rounded">
                        </div>

                        <div class="description mb-2">
                            <h4>Açıklama</h4>
                            <p>@Model.Description</p>
                        </div>

                        <div class="tour-includes mb-4">
                            <table>
                                <tbody>
                                    <tr>
                                        <td><i class="fa fa-clock-o pink mr-1" aria-hidden="true"></i> @Model.DayNight</td>
                                        <td><i class="fa fa-group pink mr-1" aria-hidden="true"></i> Kapasite : @Model.Capacity</td>
                                        <td><i class="fa fa-calendar pink mr-1" aria-hidden="true"></i> @Model.TourDate</td>
                                    </tr>
                                    <tr>
                                        <td><i class="fa fa-user pink mr-1" aria-hidden="true"></i> Minimum Yaş : 10+</td>
                                        <td><i class="fa fa-map-signs pink mr-1" aria-hidden="true"></i> Karşılama : Havalanı</td>
                                        <td><i class="fa fa-file-alt pink mr-1" aria-hidden="true"></i> Diller - İngilizce</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div id="iternary" class="accrodion-grp faq-accrodion mb-4" data-grp-name="faq-accrodion">
                        @foreach (var item in Model.TourPrograms)
                        {
                            <div class="accrodion">
                            <div class="accrodion-title rounded">
                                <h5 class="mb-0"><span>Day @item.DayNumber</span> - @item.Title</h5>
                            </div>
                            <div class="accrodion-content" style="display: block;">
                                <div class="inner">
                                    <p>@item.Description.</p>
                                </div><!-- /.inner -->
                            </div>
                        </div>
                        }
                        

                    </div>

                    <!-- Generated Image-->
                    <div id="single-map" class="single-map mb-4">
                        <h4>Tur Rotası</h4>
                        <div class="map rounded overflow-hidden">
                            <div style="width: 100%">
                                <img src="@Model.GeneratedImageUrl"
                                     alt="@Model.Title - Illustrated Map"
                                     class="w-100 rounded shadow"
                                     style="height: 400px; object-fit: cover;" />
                            </div>
                        </div>
                    </div>
                    <div class="mt-5 mb-5">
                        <a href="/Booking/CreateBooking/@Model.TourId" class="nir-btn" style="font-size: large; font-weight: bold; width: 100%; display:block;">Rezervasyon Yap</a>
                    </div>

                    
                    @await Component.InvokeAsync("_ResultReviewViewComponentPartial", new { id = Model.TourId})

                    @await Component.InvokeAsync("_TourCommentsListComponentPartial", new { tourId = Model.TourId })

                    @await Component.InvokeAsync("_TourCreateCommentComponentPartial", new { tourId = Model.TourId })

                </div>
            </div>


            <div class="col-lg-4 ps-lg-4">
                <div class="sidebar-sticky sticky1">
                    <div class="tabs-navbar bg-lgrey mb-4 bordernone rounded overflow-hidden">
                        <div class="row">
                            <div class="col-md-12">
                                <ul id="tabs" class="nav nav-tabs bordernone mb-0">
                                    <li class="active">
                                        <a data-toggle="tab" href="#highlight" class="rounded box-shadow mb-2 border-all">Öne Çıkanlar</a>
                                    </li>
                                    <li>
                                        <a data-toggle="tab" href="#iternary" class="rounded box-shadow mb-2 border-all">Rota</a>
                                    </li>
                                    <li>
                                        <a data-toggle="tab" href="#single-map" class="rounded box-shadow mb-2 border-all">Harita</a>
                                    </li>
                                    <li>
                                        <a data-toggle="tab" href="#single-review" class="rounded box-shadow mb-2 border-all">Değerlendirme</a>
                                    </li>
                                    <li>
                                        <a data-toggle="tab" href="#single-comments" class="rounded box-shadow mb-2 border-all">Yorumlar</a>
                                    </li>
                                    <li>
                                        <a data-toggle="tab" href="#single-add-review" class="rounded box-shadow mb-2 border-all">Değerlendir</a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- top Destination ends -->
<!-- Discount action starts -->
<section class="discount-action pt-0" style="background-image:url(/travelin/images/section-bg1.png); background-position:center;">
    <div class="container">
        <div class="call-banner rounded pt-10 pb-14">
            <div class="call-banner-inner w-75 mx-auto text-center px-5">
                <div class="trend-content-main">
                    <div class="trend-content mb-5 pb-2 px-5">
                        <h5 class="mb-1 theme">Yolculuğun Tadını Çıkarın</h5>
                        <h2><a href="detail-fullwidth.html">Hayatı Keşfedin, <span class="theme1"> Özgürce Seyahat Edin!</span></a></h2>
                        <p>Hayalinizdeki tatili gerçeğe dönüştürmek ve unutulmaz anılar biriktirmek için rotanızı hemen oluşturun.</p>
                    </div>
                    <div class="video-button text-center position-relative">
                        <div class="call-button text-center">
                            <button type="button" class="play-btn js-video-button" data-video-id="F02_MVdAqCk" data-channel="youtube">
                                <i class="fa fa-play bg-blue"></i>
                            </button>
                        </div>
                        <div class="video-figure"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="white-overlay"></div>
    <div class="white-overlay"></div>
    <div class="section-shape  top-inherit bottom-0" style="background-image: url(/travelin/images/shape6.png);"></div>
</section>
<!-- Discount action Ends -->

