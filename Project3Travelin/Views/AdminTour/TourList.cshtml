@model List<ResultTourDto>

@{
    ViewData["Title"] = "TourList";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    body {
        font-family: 'Inter', sans-serif;
    }

    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
</style>

<section class="p-10 max-w-7xl mx-auto">
    <div class="mb-12">
        <h2 class="text-[2.75rem] font-bold tracking-[-0.02em] text-on-surface leading-tight">Hoş geldiniz, Admin</h2>
        <p class="text-lg text-on-surface-variant mt-2 font-body max-w-2xl">Dashboard üzerinden tüm turlarınızı, rezervasyonlarınızı ve müşteri geri bildirimlerini anlık olarak yönetebilirsiniz.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/10 group hover:border-primary-container transition-all duration-300">
            <div class="flex items-center justify-between mb-6">
                <div class="w-12 h-12 rounded-full bg-secondary-container/30 flex items-center justify-center text-primary">
                    <span class="material-symbols-outlined">map</span>
                </div>
                <span class="text-xs font-bold text-primary bg-primary-fixed/20 px-3 py-1 rounded-full uppercase tracking-wider">+12%</span>
            </div>
            <p class="text-label-md text-on-surface-variant font-medium uppercase tracking-widest mb-1">Toplam Tur Sayısı</p>
            <h3 class="text-4xl font-black text-on-surface">@Model.Count</h3>
        </div>
        @await Component.InvokeAsync("_BookingStatusPendingViewComponentPartial")
        @await Component.InvokeAsync("_BookingCommentViewComponentPartial")
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
        <div class="lg:col-span-5 bg-surface-container-lowest rounded-xl p-8 border border-outline-variant/10">
            <div class="flex items-center justify-between mb-8">
                <h4 class="text-xl font-bold tracking-tight">Turlar</h4>
            </div>
            <div class="space-y-6">
                @foreach (var item in Model)
                {
                    <div class="flex items-center gap-6 p-3 group hover:bg-surface-container-highest rounded-xl transition-colors cursor-pointer border border-transparent hover:border-outline-variant/20">

                        <div class="w-28 h-20 rounded-lg bg-surface-container overflow-hidden shrink-0">
                            <img alt="@item.Title" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" src="@item.ImageUrl" />
                        </div>

                        <div class="flex-1">
                            <h4 class="text-lg font-bold text-on-surface mb-1">@item.Title</h4>
                            <p class="text-base text-on-surface-variant">@item.Country, @item.City</p>
                        </div>

                        <div class="flex-none px-4">
                            <button type="button" onclick="openCustomerModal('@item.TourId','@item.Title')" class="inline-flex items-center gap-2 bg-indigo-100 text-indigo-700 hover:bg-indigo-200 px-4 py-2 rounded-lg font-semibold text-sm transition-colors">
                                <span class="material-symbols-outlined text-lg">groups</span>
                                Tura Kaydolanlar
                            </button>
                        </div>
                        <div class="flex-none px-2">
                            <button type="button" onclick="window.location.href=`/AdminTour/UpdateTour?id=@item.TourId`" class="flex items-center justify-center text-blue-500 hover:text-red-700 hover:bg-red-50 p-2 rounded-lg transition-colors" title="Turu Güncelle">
                                <span class="material-symbols-outlined">edit</span>
                            </button>
                        </div>
                        <div class="flex-none px-2">
                            <button type="button" onclick="DeleteTour('@item.TourId')" class="flex items-center justify-center text-red-500 hover:text-red-700 hover:bg-red-50 p-2 rounded-lg transition-colors" title="Turu Sil">
                                <span class="material-symbols-outlined">delete</span>
                            </button>

                        </div>

                        <div class="text-right w-32 shrink-0">
                            <p class="text-xl font-bold text-primary">@item.Price ₺</p>
                            <p class="text-xs text-on-surface-variant font-bold uppercase mt-1">Kişi Başı</p>
                        </div>

                    </div>
                }
            </div>
        </div>
    </div>
</section>

<div id="customerModal" class="fixed inset-0 z-[9999] hidden bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 transition-opacity">
    <div class="bg-white rounded-2xl shadow-2xl w-[95%] lg:w-3/5 max-h-[80vh] overflow-hidden flex flex-col">
        <div class="flex justify-between items-center p-5 border-b border-gray-100 bg-gray-50 flex-shrink-0">
            <h3 class="text-xl font-bold text-gray-800 flex items-center gap-2">
                <span class="material-symbols-outlined text-indigo-600">groups</span>
                Tura Kayıtlı Müşteriler
            </h3>

            <div class="flex items-center gap-3">

                <a id="excelExportBtn" href="#" class="hidden inline-flex items-center gap-1.5 bg-green-600 text-white hover:bg-green-700 px-3 py-1.5 rounded-lg font-semibold text-sm transition-colors shadow-sm">
                    <span class="material-symbols-outlined text-base">download</span>
                    Excel'e Aktar
                </a>

                <button onclick="closeCustomerModal()" class="text-gray-400 hover:text-red-500 transition-colors p-1 rounded-full hover:bg-red-50">
                    <span class="material-symbols-outlined">close</span>
                </button>

            </div>
        </div>

        <div id="modalContent" class="p-6 overflow-y-auto">
        </div>
    </div>
</div>

<div id="pendingBookingsModal" class="fixed inset-0 z-[9999] hidden bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 transition-opacity">
    <div class="bg-white rounded-2xl shadow-2xl w-[95%] lg:w-3/5 max-h-[80vh] overflow-hidden flex flex-col">

        <div class="flex justify-between items-center p-5 border-b border-orange-100 bg-orange-50/50 flex-shrink-0">
            <h3 class="text-xl font-bold text-orange-700 flex items-center gap-2">
                <span class="material-symbols-outlined text-orange-500">pending_actions</span>
                Bekleyen Rezervasyonlar
            </h3>
            <button onclick="closePendingBookingsModal()" class="text-gray-400 hover:text-red-500 transition-colors p-1 rounded-full hover:bg-red-50">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <div id="pendingModalContent" class="p-6 overflow-y-auto">
        </div>

    </div>
</div>

<div id="addTourModal" class="fixed inset-0 z-[9999] hidden bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 transition-opacity">
    <div class="bg-white rounded-2xl shadow-2xl w-[95%] lg:w-3/4 max-h-[90vh] overflow-hidden flex flex-col">

        <div class="flex justify-between items-center p-5 border-b border-gray-100 bg-gray-50 flex-shrink-0">
            <h3 class="text-xl font-bold text-gray-800 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">add_location_alt</span>
                Yeni Tur & Rota Ekle
            </h3>
            <button type="button" onclick="closeAddTourModal()" class="text-gray-400 hover:text-red-500 transition-colors p-1 rounded-full hover:bg-red-50">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <form action="/AdminTour/CreateTour" method="post" class="flex flex-col h-full overflow-hidden">

            <div class="flex flex-col md:flex-row flex-1 overflow-y-auto">

                <div class="p-6 md:w-1/2 border-r border-gray-100">
                    <h4 class="font-bold text-lg mb-4 text-indigo-700 border-b pb-2">1. Temel Bilgiler</h4>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="md:col-span-2">
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Tur Adı</label>
                            <input type="text" name="Title" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" placeholder="Örn: Kapadokya Balon Turu">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Ülke</label>
                            <input type="text" name="Country" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" placeholder="Örn: Türkiye">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Şehir</label>
                            <input type="text" name="City" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" placeholder="Örn: Nevşehir">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Fiyat (₺)</label>
                            <input type="number" step="0.01" name="Price" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" placeholder="0.00">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Kontenjan (Kişi)</label>
                            <input type="number" name="Capacity" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" placeholder="Örn: 40">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Tur Tarihi</label>
                            <input type="datetime-local" name="TourDate" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Gün / Gece</label>
                            <input type="text" name="DayNight" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" placeholder="Örn: 3 Gün 2 Gece">
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Kapak Resmi URL</label>
                            <input type="text" name="ImageUrl" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" placeholder="https://...">
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Tur Açıklaması</label>
                            <textarea name="Description" rows="3" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" placeholder="Tur hakkında detaylı bilgi..."></textarea>
                        </div>
                    </div>
                </div>

                <div class="p-6 md:w-1/2 bg-gray-50/50 flex flex-col h-full">
                    <div class="flex justify-between items-center mb-4 border-b border-gray-200 pb-2">
                        <h4 class="font-bold text-lg text-indigo-700">2. Tur Programı (Günler)</h4>
                        <button type="button" onclick="addProgramDay()" class="text-sm bg-indigo-100 text-indigo-700 hover:bg-indigo-200 px-3 py-1.5 rounded-lg font-semibold transition-colors flex items-center gap-1">
                            <span class="material-symbols-outlined text-sm">add</span> Gün Ekle
                        </button>
                    </div>

                    <div id="programContainer" class="space-y-4 overflow-y-auto flex-1 pr-2">
                        <div class="program-item bg-white p-4 rounded-xl shadow-sm border border-gray-100 relative group">
                            <div class="flex justify-between items-center mb-2">
                                <span class="font-bold text-sm text-gray-800 bg-gray-100 px-2 py-1 rounded">1. Gün</span>
                                <button type="button" onclick="this.closest('.program-item').remove(); updateProgramIndexes();" class="text-red-400 hover:text-red-600 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <span class="material-symbols-outlined text-sm">delete</span>
                                </button>
                            </div>

                            <input type="hidden" name="TourPrograms[0].DayNumber" value="1" class="day-number-input">

                            <div class="space-y-3">
                                <div>
                                    <input type="text" name="TourPrograms[0].Title" required class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none" placeholder="Gün Başlığı (Örn: Uçuş ve Otele Yerleşme)">
                                </div>
                                <div>
                                    <textarea name="TourPrograms[0].Description" rows="2" required class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none" placeholder="O gün yapılacakların detaylı açıklaması..."></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <div class="w-full p-4 border-t border-gray-200 bg-gray-50 flex justify-end gap-3 shrink-0">
                <button type="button" onclick="closeAddTourModal()" class="px-5 py-2 text-gray-600 font-semibold hover:bg-gray-200 rounded-lg transition-colors">
                    İptal
                </button>
                <button type="submit" class="px-5 py-2 bg-primary text-white font-bold rounded-lg hover:bg-primary/90 transition-colors flex items-center gap-2 shadow-md">
                    <span class="material-symbols-outlined text-sm">save</span>
                    Turu ve Rotayı Kaydet
                </button>
            </div>

        </form>

    </div>
</div>

<button type="button" onclick="openAddTourModal()" class="fixed bottom-10 right-10 w-16 h-16 rounded-full bg-gradient-to-br from-primary-container to-primary text-on-primary shadow-2xl flex items-center justify-center hover:scale-110 transition-transform cursor-pointer active:scale-95 z-50">
    <span class="material-symbols-outlined text-3xl">add</span>
</button>

<script>
        // --- BEKLEYEN REZERVASYON MODALI ---
    function openPendingBookingsModal() {
        document.getElementById('pendingBookingsModal').classList.remove('hidden');
        const contentDiv = document.getElementById('pendingModalContent');

        // Yükleniyor animasyonu
        contentDiv.innerHTML = `
            <div class="text-center py-10 text-orange-500">
                <span class="material-symbols-outlined animate-spin text-4xl">autorenew</span>
                <p class="mt-2 text-gray-600 font-medium">Bekleyen rezervasyonlar getiriliyor...</p>
            </div>`;

        // Örnek: BookingController içindeki GetPendingBookingsPartial metodu
        fetch('/AdminTour/GetPendingRezervasition')
            .then(response => {
                if (!response.ok) throw new Error('Network error');
                return response.text();
            })
            .then(html => {
                contentDiv.innerHTML = html; // C#'tan gelen tabloyu ekrana bas!
            })
            .catch(error => {
                contentDiv.innerHTML = '<p class="text-center text-red-500 py-10 font-bold">Rezervasyonlar yüklenirken bir hata oluştu.</p>';
            });
    }

    function closePendingBookingsModal() {
        document.getElementById('pendingBookingsModal').classList.add('hidden');
    }

    // Opsiyonel: Onayla ve Reddet butonları için taslak JS fonksiyonları
    function ApproveBooking(id) {
        if(confirm("Bu rezervasyonu onaylamak istediğinize emin misiniz?")) {
            window.location.href = `/AdminTour/ApproveBooking?id=${id}`;
        }
    }

    function RejectBooking(id) {
        if(confirm("Bu rezervasyonu reddetmek istediğinize emin misiniz?")) {
            window.location.href = `/AdminTour/RejectBooking?id=${id}`;
        }
    }

    function UpdateTour(tourId){
        window.location.href = `/AdminTour/UpdateTour?id=${tourId}`;
    }

    function DeleteTour(tourId){
        const isConfirmed = confirm("Turu silmek istediğinize emin misiniz?");
        if(isConfirmed){
            window.location.href = `/AdminTour/DeleteTour?id=${tourId}`;
        }
    }

    let programIndex = 1; // Başlangıçta 0. index (1. gün) zaten var

    function addProgramDay() {
        const container = document.getElementById('programContainer');
        const dayCount = container.children.length + 1; // Kaçıncı gün olduğunu hesapla

        // Yeni program HTML'ini oluştur
        const newProgramHTML = `
            <div class="program-item bg-white p-4 rounded-xl shadow-sm border border-gray-100 relative group animate-fade-in">
                <div class="flex justify-between items-center mb-2">
                    <span class="font-bold text-sm text-gray-800 bg-gray-100 px-2 py-1 rounded day-badge">${dayCount}. Gün</span>
                    <button type="button" onclick="this.closest('.program-item').remove(); updateProgramIndexes();" class="text-red-400 hover:text-red-600 opacity-0 group-hover:opacity-100 transition-opacity">
                        <span class="material-symbols-outlined text-sm">delete</span>
                    </button>
                </div>

                <input type="hidden" name="TourPrograms[${programIndex}].DayNumber" value="${dayCount}" class="day-number-input">

                <div class="space-y-3">
                    <div>
                        <input type="text" name="TourPrograms[${programIndex}].Title" required class="title-input w-full px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none" placeholder="Gün Başlığı (Örn: Şehir Turu)">
                    </div>
                    <div>
                        <textarea name="TourPrograms[${programIndex}].Description" rows="2" required class="desc-input w-full px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none" placeholder="O gün yapılacakların detaylı açıklaması..."></textarea>
                    </div>
                </div>
            </div>
        `;

        // Kutuyu ekrana bas
        container.insertAdjacentHTML('beforeend', newProgramHTML);
        programIndex++;
        updateProgramIndexes(); // Her eklemeden sonra isimleri düzenle
    }

    // Araya gün eklenip silinirse, C# modelinin bozulmaması için indexleri sırayla güncelleyen kritik fonksiyon
    function updateProgramIndexes() {
        const items = document.querySelectorAll('.program-item');
        items.forEach((item, index) => {
            const dayNum = index + 1;

            // Görsel rozeti güncelle (Örn: 2. Gün)
            item.querySelector('.day-badge').innerText = `${dayNum}. Gün`;

            // Gizli inputu güncelle
            item.querySelector('.day-number-input').value = dayNum;
            item.querySelector('.day-number-input').name = `TourPrograms[${index}].DayNumber`;

            // Title ve Description name'lerini MVC'ye uygun hale getir
            item.querySelector('.title-input').name = `TourPrograms[${index}].Title`;
            item.querySelector('.desc-input').name = `TourPrograms[${index}].Description`;
        });

        programIndex = items.length; // Sayacı mevcut duruma eşitle
    }
    function openCustomerModal(tourId, title) {
        // Modalı aç
        document.getElementById('customerModal').classList.remove('hidden');
        const contentDiv = document.getElementById('modalContent');

        const excelBtn = document.getElementById('excelExportBtn');
        excelBtn.href = `/Booking/DownloadExcel?tourId=${tourId}&title=${encodeURIComponent(title)}`; // Linki anlık olarak oluştur
        excelBtn.classList.remove('hidden'); // Butonu görünür yap

        // Yükleniyor animasyonunu göster
        contentDiv.innerHTML = `
            <div class="text-center py-10 text-gray-500">
                <span class="material-symbols-outlined animate-spin text-4xl">autorenew</span>
                <p class="mt-2">Veriler getiriliyor...</p>
            </div>`;

        // Controller'dan veriyi çek
        fetch(`/Booking/GetPassergerByTourId?id=${tourId}`)
            .then(response => {
                if (!response.ok) throw new Error('Network error');
                return response.text();
            })
            .then(html => {
                // Gelen tabloyu içeri bas
                contentDiv.innerHTML = html;
            })
            .catch(error => {
                contentDiv.innerHTML = '<p class="text-center text-red-500 py-10 font-bold">Veriler yüklenirken bir hata oluştu.</p>';
            });
    }

    function closeCustomerModal() {
        // Modalı gizle
        document.getElementById('customerModal').classList.add('hidden');
        }

        function openAddTourModal() {
        document.getElementById('addTourModal').classList.remove('hidden');
        }

        function closeAddTourModal() {
            document.getElementById('addTourModal').classList.add('hidden');
        }

</script>