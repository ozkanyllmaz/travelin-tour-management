@model List<PendingBookingsDto>

@if (Model != null && Model.Any())
{
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-orange-50 text-orange-800 text-sm border-b border-orange-100">
                    <th class="p-4 font-bold rounded-tl-lg">Müşteri</th>
                    <th class="p-4 font-bold">Tur Adı</th>
                    <th class="p-4 font-bold">Kişi Sayısı</th>
                    <th class="p-4 font-bold">Tarih</th>
                    <th class="p-4 font-bold text-right rounded-tr-lg">İşlem</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                @foreach (var item in Model)
                {
                    <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                        <td class="p-4 font-semibold text-gray-800">
                            @item.FirstName @item.LastName
                        </td>
                        <td class="p-4 text-gray-600">@item.TourTitle</td>
                        <td class="p-4 text-gray-600">
                            <span class="bg-gray-100 text-gray-700 px-2 py-1 rounded font-bold">@item.PassengerCount Kişi</span>
                        </td>
                        <td class="p-4 text-gray-500">@item.BookingDate.ToString("dd MMM yyyy")</td>

                        <td class="p-4 text-right flex justify-end gap-2">
                            <button onclick="ApproveBooking('@item.BookingId')" class="bg-green-100 text-green-700 hover:bg-green-200 p-2 rounded-lg transition-colors" title="Onayla">
                                <span class="material-symbols-outlined text-base">check_circle</span>
                            </button>
                            <button onclick="RejectBooking('@item.BookingId')" class="bg-red-100 text-red-700 hover:bg-red-200 p-2 rounded-lg transition-colors" title="Reddet">
                                <span class="material-symbols-outlined text-base">cancel</span>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-orange-50 text-orange-800 text-sm border-b border-orange-100">
                    <th class="p-4 font-bold rounded-tl-lg">Müşteri</th>
                    <th class="p-4 font-bold">Tur Adı</th>
                    <th class="p-4 font-bold">Kişi Sayısı</th>
                    <th class="p-4 font-bold">Tarih</th>
                    <th class="p-4 font-bold text-right rounded-tr-lg">İşlem</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                    <td class="p-4 font-semibold text-gray-800">
                        <span>Bekleyen hiç bir rezervasyon yok!</span>
                    </td>

                </tr>
            </tbody>
        </table>
    </div>
}