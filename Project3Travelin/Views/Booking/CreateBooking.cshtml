@model CreateBookingDto

@{
    ViewData["Title"] = "CreateBooking";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

<style>
    .booking-card {
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        background-color: #ffffff;
    }

    .booking-info-panel {
        background-color: #fafbfd; /* Sol tarafın çok hafif gri/mavi arka planı */
    }

    .custom-input {
        border-radius: 10px;
        padding: 14px 18px;
        border: 1px solid #eaedf1;
        background-color: #ffffff;
        font-size: 15px;
        color: #495057;
    }

        .custom-input:focus {
            border-color: #28a745;
            box-shadow: none;
        }

    .custom-btn {
        border-radius: 10px;
        background-color: #22c55e;
        border: none;
        font-size: 16px;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
    }

        .custom-btn:hover {
            background-color: #1ea951;
        }

    .feature-icon {
        color: #22c55e;
        font-size: 20px;
        width: 30px;
    }
    /* Yolcu ikonunu inputun içine yerleştirmek için */
    .icon-input-wrapper {
        position: relative;
    }

        .icon-input-wrapper i {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: #adb5bd;
        }

        .icon-input-wrapper input {
            padding-left: 45px;
        }
</style>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="booking-card">
                <div class="row g-0 m-0">

                    @await Component.InvokeAsync("_BookingTourViewComponentPartial", new { id = Model.TourId })

                    <div class="col-md-7 p-4 p-md-5">

                        <form asp-controller="Booking" asp-action="CreateBooking" method="post">

                            <input type="hidden" asp-for="TourId" />

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <input asp-for="FirstName" class="form-control custom-input" placeholder="İsim" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <input asp-for="LastName" class="form-control custom-input" placeholder="Soyisim" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <input asp-for="Email" type="email" class="form-control custom-input" placeholder="Mail" required>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <input asp-for="Phone" type="tel" class="form-control custom-input" placeholder="Telefon" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="icon-input-wrapper">
                                        
                                        <input asp-for="PassengerCount" type="number" min="1" class="form-control custom-input" placeholder="Kişi Sayısı" required>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-4">
                                <input type="date" name="TourDate" class="form-control custom-input text-muted" required>
                            </div>

                            <button type="submit" class="btn btn-success w-100 custom-btn py-3 font-weight-bold text-white">
                                Rezervasyonu Tamamla
                            </button>

                        </form>

                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

