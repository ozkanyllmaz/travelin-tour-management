@model List<ResultBookingDto>

@if (Model == null || !Model.Any())
{
    <div class="text-center py-8 text-gray-500">
        <span class="material-symbols-outlined text-4xl mb-2">person_off</span>
        <p>Bu tura henüz kayıtlı müşteri bulunmamaktadır.</p>
    </div>
}
else
{
    <div class="overflow-x-auto">
        
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-100 text-gray-700 text-sm">
                    <th class="p-3 rounded-tl-lg">Müşteri Adı</th>
                    <th class="p-3">Telefon</th>
                    <th class="p-3">E-posta</th>
                    <th class="p-3 text-center">Kişi Sayısı</th>
                    <th class="p-3 rounded-tr-lg">Kayıt Tarihi</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                @foreach (var item in Model)
                {
                    <tr class="border-b border-gray-100 hover:bg-gray-50">
                        <td class="p-3 font-semibold text-gray-800">@item.FirstName @item.LastName</td>
                        <td class="p-3 text-gray-600">@item.Phone</td>
                        <td class="p-3 text-gray-600">@item.Email</td>
                        <td class="p-3 text-center">
                            <span class="bg-indigo-100 text-indigo-700 px-2 py-1 rounded-full font-bold">@item.PassengerCount</span>
                        </td>
                        <td class="p-3 text-gray-500">@item.BookingDate.ToString("dd.MM.yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}