


<div id="single-review" class="single-review mb-4 mt-5">
    <h4>Değerlendirmeler</h4>
    <div class="row d-flex align-items-center">
        <div class="col-lg-4 col-md-4">
            <div class="review-box bg-title text-center py-4 p-2 rounded">
                <h2 class="mb-1 white"><span>@ViewBag.Rating.ToString("0.#")</span>/5</h2>
                <h4 class="white mb-1">Genel Değerlendirme</h4>
                <p class="mb-0 white font-italic"></p>
            </div>
        </div>
        <div class="col-lg-8 col-md-8">
            <div class="review-progress">
                <div class="progress-item mb-1">
                    <p class="mb-0">Rehber</p>
                    <div class="progress rounded">
                        <div class="progress-bar bg-theme" role="progressbar" aria-valuenow="@ViewBag.Guide" aria-valuemin="0" aria-valuemax="5" style="width:40%">
                            <span class="sr-only">@(ViewBag.Guide * 20)% Complete</span>
                        </div>
                    </div>
                </div>
                <div class="progress-item mb-1">
                    <p class="mb-0">Program</p>
                    <div class="progress rounded">
                        <div class="progress-bar bg-theme" role="progressbar" aria-valuenow="@ViewBag.Program" aria-valuemin="0" aria-valuemax="5" style="width:30%">
                            <span class="sr-only">@(ViewBag.Program * 20)% Complete</span>
                        </div>
                    </div>
                </div>
                <div class="progress-item mb-1">
                    <p class="mb-0">Fiyat Performans</p>
                    <div class="progress rounded">
                        <div class="progress-bar bg-theme" role="progressbar" aria-valuenow="@ViewBag.ValueForMoney" aria-valuemin="0" aria-valuemax="5" style="width:60%">
                            <span class="sr-only">@(ViewBag.ValueForMoney * 20)% Complete</span>
                        </div>
                    </div>
                </div>
                <div class="progress-item mb-1">
                    <p class="mb-0">Organizasyon</p>
                    <div class="progress rounded">
                        <div class="progress-bar bg-theme" role="progressbar" aria-valuenow="@ViewBag.Organization" aria-valuemin="0" aria-valuemax="5" style="width:20%">
                            <span class="sr-only">@(ViewBag.Organization * 20)% Complete</span>
                        </div>
                    </div>
                </div>
                <div class="progress-item">
                    <p class="mb-0">Hizmet</p>
                    <div class="progress rounded">
                        <div class="progress-bar bg-theme" role="progressbar" aria-valuenow="@ViewBag.Service" aria-valuemin="0" aria-valuemax="5" style="width:45%">
                            <span class="sr-only">@(ViewBag.Service * 20)% Complete</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>